{
  "manifest_version": 3,
  "name": "CompileLink for Codeforces",
  "version": "1.0.0",
  "description": "Solve Codeforces problems on compiler.rijoan.com with one click.",
  "permissions": ["storage", "tabs", "activeTab", "scripting"],
  "host_permissions": [
    "https://codeforces.com/*",
    "https://compiler.rijoan.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/problemset/problem/*/*",
        "https://codeforces.com/contest/*/problem/*",
        "https://codeforces.com/gym/*/problem/*"
      ],
      "js": ["content-scripts/codeforces.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://compiler.rijoan.com/*"],
      "js": ["content-scripts/compiler-injector.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo128.png",
    "48": "icons/logo128.png",
    "128": "icons/logo128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/logo128.png",
      "48": "icons/logo128.png",
      "128": "icons/logo128.png"
    }
  }
}
